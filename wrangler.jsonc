{
  "name": "checktourup",
  "compatibility_date": "2026-07-15",
  "main": "src/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "DATA",
      "id": "PASTE_YOUR_KV_NAMESPACE_ID_HERE"
    }
  ]
}
